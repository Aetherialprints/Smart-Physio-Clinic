# Smart Physio Clinic - Environment Variables
# Copy to .env and fill in production values

# Django
DJANGO_SECRET_KEY=pcms-production-secret-key-change-this-2026-x7k9m2p4
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=pcms_db
DB_USER=pcms_user
DB_PASSWORD=pcms_secure_password_change_this
DB_HOST=db
DB_PORT=5432

# Use SQLite for development (set to False for production)
USE_SQLITE=False

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailEmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@smartphysio.com

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Redis/Celery
REDIS_URL=redis://redis:6379/0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Clinic Info
CLINIC_NAME=Smart Physio Clinic
CLINIC_ADDRESS=123 Medical Street, Casablanca, Morocco
CLINIC_PHONE=+212-5-0000-0000
